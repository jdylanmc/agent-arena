{
  "name": "agent-arena",
  "displayName": "Agent Arena",
  "description": "Orchestration engine for managing multiple autonomous agents inside VS Code",
  "version": "0.0.1",
  "publisher": "jdylanmc",
  "license": "MIT",
  "private": true,
  "author": "Dylan McCurry",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdylanmc/agent-arena.git",
    "directory": "extension"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agentArenaPrimaryView",
    "onCommand:agent-arena.openPrimaryAgent",
    "onCommand:agent-arena.toggleYolo",
    "onCommand:agent-arena.showTraceLog",
    "onCommand:agent-arena.harness.export",
    "onCommand:agent-arena.harness.import",
    "onStartupFinished"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentArena",
          "title": "Agent Arena",
          "icon": "icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "agentArena": [
        {
          "id": "agentArenaPrimaryView",
          "name": "Primary Agent"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentArenaPrimaryView",
        "contents": "## Agent Arena\n\nThe primary agent runs in a dedicated editor-area panel — split, maximize, or drag it like any other tab.\n\n[Open Primary Agent Panel](command:agent-arena.openPrimaryAgent)\n\nSigned in to GitHub Copilot? You'll talk to a real model. Otherwise the panel falls back to demo mode so the round-trip surface is still visible.\n\n[Show trace log](command:agent-arena.showTraceLog)"
      }
    ],
    "commands": [
      {
        "command": "agent-arena.openPrimaryAgent",
        "title": "Agent Arena: Open Primary Agent"
      },
      {
        "command": "agent-arena.toggleYolo",
        "title": "Agent Arena: Toggle Yolo"
      },
      {
        "command": "agent-arena.showTraceLog",
        "title": "Agent Arena: Show Trace Log"
      },
      {
        "command": "agent-arena.harness.export",
        "title": "Agent Arena: Export Harness..."
      },
      {
        "command": "agent-arena.harness.import",
        "title": "Agent Arena: Import Harness..."
      }
    ],
    "configuration": {
      "title": "Agent Arena",
      "properties": {
        "agentArena.primaryAgent.model": {
          "type": "string",
          "default": "gpt-5.2-codex",
          "description": "Default model id for the primary agent. Resolved against the SDK's model listing at startup; falls back to the first available chat-class model if not entitled."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist && rimraf --glob \"*.vsix\"",
    "build": "npm run build:host && npm run build:webview",
    "build:host": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "dev": "node esbuild.config.mjs --watch",
    "launch": "npm run build && node scripts/launch.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vscode-test",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern node_modules",
    "lint:fix": "eslint . --fix --ignore-pattern dist --ignore-pattern node_modules",
    "format": "prettier --write \"src/**/*.ts\" \"webview-src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"webview-src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run clean && npm run build"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.0.0",
    "mocha": "^10.7.0",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rimraf": "^6.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
